# Copy to .env and fill in. Do not commit .env.
# Required
DB_URL=postgresql://user:password@localhost:5432/cardinalcast
JWT_SECRET=your_jwt_secret_here_min_32_chars

# Optional — required for NOAA weather ingestion
# NOAA_CDO_TOKEN=your_noaa_cdo_token

# Frontend (frontend/.env) — skips login screen during local dev only.
# Has no effect in production builds (vite build strips import.meta.env.DEV).
# VITE_DEV_BYPASS_AUTH=true
